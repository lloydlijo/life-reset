# Copy this to .env and fill in your values
# On Railway, set these as environment variables in the dashboard

NODE_ENV=production
PORT=5000

# Change this to a long random string in production!
JWT_SECRET=change-me-to-something-random-and-long-in-production

# Optional: where SQLite database file is stored
# On Railway, use a volume mount or leave default
DATA_DIR=./data
